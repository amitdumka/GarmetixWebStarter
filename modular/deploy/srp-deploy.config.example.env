# Copy this file to ~/.config/garmetix/srp-deploy.env and edit for the SRP host.
# Do not store passwords, Cloudflare tokens, SSH private keys, or database secrets here.

SRP_DEPLOY_TARGET=amitkumar@192.168.11.127
SRP_SSH_PORT=22
SRP_SECRETS_PATH=~/.config/garmetix/srp-deploy.secrets.env
SRP_DOMAIN=srp.aadwikafashion.in
SRP_REMOTE_BASE=/opt/garmetix-srp
SRP_NGINX_PORT=8088
SRP_API_PORT=5080
SRP_KEEP_RELEASES=5
SRP_PATH_BASED_URLS=true

SRP_PUBLIC_API_BASE_URL=/api
SRP_MAIN_URL=/
SRP_POS_URL=/pos/
SRP_HR_URL=/hr/
SRP_AI_SENSE_URL=/ai-sense/
SRP_BOOKS_URL=/books/
SRP_ADMIN_URL=/admin/

SRP_MAIN_BASE_PATH=/
SRP_POS_BASE_PATH=/pos/
SRP_HR_BASE_PATH=/hr/
SRP_AI_SENSE_BASE_PATH=/ai-sense/
SRP_BOOKS_BASE_PATH=/books/
SRP_ADMIN_BASE_PATH=/admin/

SRP_API_PROJECT=legacy/backend/Garmetix.Api/Garmetix.Api.csproj
SRP_SKIP_API_PUBLISH=false
SRP_API_PUBLISH_SELF_CONTAINED=true
SRP_API_RUNTIME=linux-x64

SRP_API_ENV_PATH=/etc/garmetix/srp-api.env
SRP_CLOUDFLARE_TUNNEL_NAME=garmetix-srp
SRP_CLOUDFLARE_CREDENTIALS_FILE=/etc/cloudflared/garmetix-srp.json
SRP_CLOUDFLARE_CONFIG_PATH=/etc/cloudflared/garmetix-srp.yml

# Optional private file, never commit it:
# ~/.config/garmetix/srp-deploy.secrets.env
#
# SRP_SSH_PASSWORD=CHANGE_ME
# SRP_SUDO_PASSWORD=CHANGE_ME
# SRP_CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME
# SRP_CLOUDFLARE_LOCAL_CREDENTIALS_FILE=/secure/path/garmetix-srp.json
# SRP_CLOUDFLARE_CREDENTIALS_JSON_B64=CHANGE_ME

# Copy this file to ~/.config/garmetix/srp-deploy.env and edit for the SRP host.
# Do not store passwords, Cloudflare tokens, SSH private keys, or database secrets here.

SRP_DEPLOY_TARGET=amitkumr@192.168.11.127
SRP_SSH_PORT=22
SRP_DOMAIN=srp.aadwikafashion.in
SRP_REMOTE_BASE=/opt/garmetix-srp
SRP_NGINX_PORT=8088
SRP_API_PORT=5080
SRP_KEEP_RELEASES=5

SRP_PUBLIC_API_BASE_URL=https://srp.aadwikafashion.in/api
SRP_MAIN_URL=https://srp.aadwikafashion.in
SRP_POS_URL=https://srp.aadwikafashion.in/pos
SRP_HR_URL=https://srp.aadwikafashion.in/hr
SRP_AI_SENSE_URL=https://srp.aadwikafashion.in/ai-sense
SRP_BOOKS_URL=https://srp.aadwikafashion.in/books
SRP_ADMIN_URL=https://srp.aadwikafashion.in/admin

SRP_MAIN_BASE_PATH=/
SRP_POS_BASE_PATH=/pos/
SRP_HR_BASE_PATH=/hr/
SRP_AI_SENSE_BASE_PATH=/ai-sense/
SRP_BOOKS_BASE_PATH=/books/
SRP_ADMIN_BASE_PATH=/admin/

SRP_API_PROJECT=legacy/backend/Garmetix.Api/Garmetix.Api.csproj
SRP_SKIP_API_PUBLISH=false

SRP_API_ENV_PATH=/etc/garmetix/srp-api.env
SRP_CLOUDFLARE_TUNNEL_NAME=garmetix-srp
SRP_CLOUDFLARE_CREDENTIALS_FILE=/etc/cloudflared/garmetix-srp.json
SRP_CLOUDFLARE_CONFIG_PATH=/etc/cloudflared/garmetix-srp.yml

    "smoke:visual": "node scripts/smoke-visual-notes.mjs",
    "main:backoffice-readiness": "node scripts/main-backoffice-readiness.mjs",
    "main:backoffice-contract": "node scripts/main-backoffice-contract-check.mjs",
    "main:browser-acceptance": "node scripts/main-backoffice-browser-acceptance.mjs",
    "main:writable-readiness": "node scripts/main-writable-readiness.mjs",
    "main:stage13e-closure": "node scripts/main-stage13e-closure.mjs",
    "pos:contract": "node scripts/pos-sale-contract-check.mjs",
    "pos:operator-acceptance": "node scripts/pos-operator-acceptance.mjs",

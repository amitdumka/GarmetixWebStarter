    "build:pos": "npm --workspace @garmetix/pos-web run build",
    "build:hr": "npm --workspace @garmetix/hr-web run build",
    "build:ai-sense": "npm --workspace @garmetix/ai-sense-web run build",
    "build:books": "npm --workspace @garmetix/books-web run build",
    "build:admin": "npm --workspace @garmetix/admin-web run build",

{
  "name": "@garmetix/modular",
  "private": true,
  "version": "5.13.5",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check": "node scripts/validate-structure.mjs",
    "validate": "node scripts/validate-all.mjs",
    "deploy:preflight": "node scripts/deploy-preflight.mjs",
    "release:checklist": "node scripts/release-checklist.mjs",
    "smoke:checklist": "node scripts/smoke-checklist.mjs",
    "smoke:routes": "node scripts/smoke-local-routes.mjs",
    "smoke:api": "node scripts/smoke-api-auth.mjs",
    "smoke:public": "node scripts/smoke-public-report.mjs",
    "smoke:visual": "node scripts/smoke-visual-notes.mjs",
    "build:main": "npm --workspace @garmetix/main-web run build",
    "build:pos": "npm --workspace @garmetix/pos-web run build",
    "build:hr": "npm --workspace @garmetix/hr-web run build",
    "build:ai-sense": "npm --workspace @garmetix/ai-sense-web run build",
    "build:books": "npm --workspace @garmetix/books-web run build",
    "build:admin": "npm --workspace @garmetix/admin-web run build",
    "deploy:main": "bash deploy/main-static-deploy.sh",
    "deploy:pos": "bash deploy/pos-static-deploy.sh",
    "deploy:hr": "bash deploy/hr-static-deploy.sh",
    "deploy:ai-sense": "bash deploy/ai-sense-static-deploy.sh",
    "deploy:books": "bash deploy/books-static-deploy.sh",
    "deploy:admin": "bash deploy/admin-static-deploy.sh"
  },
  "overrides": {
    "@babel/generator": "8.0.0-rc.6",
    "@babel/parser": "8.0.0-rc.6",
    "@babel/types": "8.0.0-rc.6"
  },
  "devDependencies": {
    "@iconify-json/lucide": "1.2.114",
    "@nuxt/ui": "4.9.0",
    "nuxt": "4.4.8",
    "tailwindcss": "4.3.1",
    "vue": "3.5.38"
  }
}

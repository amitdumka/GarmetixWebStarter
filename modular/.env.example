# Shared API target for every modular frontend.
NUXT_PUBLIC_GARMETIX_API_BASE_URL=http://localhost:5080/api

# Public app URLs, usually wired through Cloudflare Tunnel in production.
NUXT_PUBLIC_GARMETIX_MAIN_URL=http://localhost:3100
NUXT_PUBLIC_GARMETIX_POS_URL=http://localhost:3101
NUXT_PUBLIC_GARMETIX_HR_URL=http://localhost:3102
NUXT_PUBLIC_GARMETIX_AI_SENSE_URL=http://localhost:3103
NUXT_PUBLIC_GARMETIX_BOOKS_URL=http://localhost:3104
NUXT_PUBLIC_GARMETIX_ADMIN_URL=http://localhost:3105

# Production examples should be configured outside source control:
# NUXT_PUBLIC_GARMETIX_API_BASE_URL=https://api.example-domain.in/api
# NUXT_PUBLIC_GARMETIX_POS_URL=https://pos.example-domain.in


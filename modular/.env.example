# Shared API target for every modular frontend.
NUXT_PUBLIC_GARMETIX_API_BASE_URL=http://localhost:5080/api

# Public app URLs, usually wired through Cloudflare Tunnel in production.
NUXT_PUBLIC_GARMETIX_MAIN_URL=http://localhost:3100
NUXT_PUBLIC_GARMETIX_POS_URL=http://localhost:3101
NUXT_PUBLIC_GARMETIX_HR_URL=http://localhost:3102
NUXT_PUBLIC_GARMETIX_AI_SENSE_URL=http://localhost:3103
NUXT_PUBLIC_GARMETIX_BOOKS_URL=http://localhost:3104
NUXT_PUBLIC_GARMETIX_ADMIN_URL=http://localhost:3105

# Compatibility aliases from planning prompts. Prefer the GARMETIX_* keys above
# in modular code, but these may be read by deploy adapters later.
NUXT_PUBLIC_API_BASE_URL=http://localhost:5080/api
NUXT_PUBLIC_MAIN_WEB_URL=http://localhost:3100
NUXT_PUBLIC_POS_WEB_URL=http://localhost:3101
NUXT_PUBLIC_HR_WEB_URL=http://localhost:3102
NUXT_PUBLIC_AI_SENSE_WEB_URL=http://localhost:3103
NUXT_PUBLIC_ACCOUNTING_WEB_URL=http://localhost:3104
NUXT_PUBLIC_SAAS_WEB_URL=http://localhost:3105

# Production examples should be configured outside source control:
# NUXT_PUBLIC_GARMETIX_API_BASE_URL=https://api.example-domain.in/api
# NUXT_PUBLIC_GARMETIX_POS_URL=https://pos.example-domain.in

# Optional POS static deploy variables. Do not commit passwords or tokens.
# POS_DEPLOY_TARGET=amit@192.168.11.126
# POS_DEPLOY_REMOTE_DIR=/var/www/garmetix/pos
# POS_DEPLOY_SSH_PORT=22
# POS_DEPLOY_KEEP_RELEASES=5

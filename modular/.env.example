# Shared API target for every modular frontend.
NUXT_PUBLIC_GARMETIX_API_BASE_URL=http://localhost:5080/api

# Public app URLs, usually wired through Cloudflare Tunnel in production.
NUXT_PUBLIC_GARMETIX_MAIN_URL=http://localhost:3100
NUXT_PUBLIC_GARMETIX_POS_URL=http://localhost:3101
NUXT_PUBLIC_GARMETIX_HR_URL=http://localhost:3102
NUXT_PUBLIC_GARMETIX_AI_SENSE_URL=http://localhost:3103
NUXT_PUBLIC_GARMETIX_BOOKS_URL=http://localhost:3104
NUXT_PUBLIC_GARMETIX_ADMIN_URL=http://localhost:3105

# Optional base paths for one-domain static hosting.
# The SRP deploy script sets these during build for srp.aadwikafashion.in.
NUXT_PUBLIC_GARMETIX_MAIN_BASE_PATH=/
NUXT_PUBLIC_GARMETIX_POS_BASE_PATH=/pos/
NUXT_PUBLIC_GARMETIX_HR_BASE_PATH=/hr/
NUXT_PUBLIC_GARMETIX_AI_SENSE_BASE_PATH=/ai-sense/
NUXT_PUBLIC_GARMETIX_BOOKS_BASE_PATH=/books/
NUXT_PUBLIC_GARMETIX_ADMIN_BASE_PATH=/admin/

# Compatibility aliases from planning prompts. Prefer the GARMETIX_* keys above
# in modular code, but these may be read by deploy adapters later.
NUXT_PUBLIC_API_BASE_URL=http://localhost:5080/api
NUXT_PUBLIC_MAIN_WEB_URL=http://localhost:3100
NUXT_PUBLIC_POS_WEB_URL=http://localhost:3101
NUXT_PUBLIC_HR_WEB_URL=http://localhost:3102
NUXT_PUBLIC_AI_SENSE_WEB_URL=http://localhost:3103
NUXT_PUBLIC_ACCOUNTING_WEB_URL=http://localhost:3104
NUXT_PUBLIC_SAAS_WEB_URL=http://localhost:3105

# Production examples should be configured outside source control:
# NUXT_PUBLIC_GARMETIX_API_BASE_URL=https://api.example-domain.in/api
# NUXT_PUBLIC_GARMETIX_POS_URL=https://pos.example-domain.in

# Optional Main Back Office static deploy variables. Do not commit passwords or tokens.
# MAIN_DEPLOY_TARGET=amit@192.168.11.126
# MAIN_DEPLOY_REMOTE_DIR=/var/www/garmetix/main
# MAIN_DEPLOY_SSH_PORT=22
# MAIN_DEPLOY_KEEP_RELEASES=5

# Optional POS static deploy variables. Do not commit passwords or tokens.
# POS_DEPLOY_TARGET=amit@192.168.11.126
# POS_DEPLOY_REMOTE_DIR=/var/www/garmetix/pos
# POS_DEPLOY_SSH_PORT=22
# POS_DEPLOY_KEEP_RELEASES=5

# Optional HR static deploy variables. Do not commit passwords or tokens.
# HR_DEPLOY_TARGET=amit@192.168.11.126
# HR_DEPLOY_REMOTE_DIR=/var/www/garmetix/hr
# HR_DEPLOY_SSH_PORT=22
# HR_DEPLOY_KEEP_RELEASES=5

# Optional AI Sense static deploy variables. Do not commit passwords or tokens.
# AI_SENSE_DEPLOY_TARGET=amit@192.168.11.126
# AI_SENSE_DEPLOY_REMOTE_DIR=/var/www/garmetix/ai-sense
# AI_SENSE_DEPLOY_SSH_PORT=22
# AI_SENSE_DEPLOY_KEEP_RELEASES=5

# Optional Books static deploy variables. Do not commit passwords or tokens.
# BOOKS_DEPLOY_TARGET=amit@192.168.11.126
# BOOKS_DEPLOY_REMOTE_DIR=/var/www/garmetix/books
# BOOKS_DEPLOY_SSH_PORT=22
# BOOKS_DEPLOY_KEEP_RELEASES=5

# Optional Admin/SaaS static deploy variables. Do not commit passwords or tokens.
# ADMIN_DEPLOY_TARGET=amit@192.168.11.126
# ADMIN_DEPLOY_REMOTE_DIR=/var/www/garmetix/admin
# ADMIN_DEPLOY_SSH_PORT=22
# ADMIN_DEPLOY_KEEP_RELEASES=5

# Optional host aliases for deployment preflight. Use SSH keys or interactive prompts.
# GARMETIX_DEPLOY_SERVER_TARGET=amit@192.168.11.126
# GARMETIX_DEPLOY_SERVER_SSH_PORT=22
# GARMETIX_DEPLOY_DESKTOP_TARGET=amitkumar@192.168.11.127
# GARMETIX_DEPLOY_DESKTOP_SSH_PORT=22

# Optional SRP whole-site deploy lane. Prefer creating this outside git with:
# bash modular/deploy/srp-whole-site-deploy.sh --init-config
# GARMETIX_SRP_DEPLOY_CONFIG=~/.config/garmetix/srp-deploy.env

POSTGRES_DB=garmetix
POSTGRES_USER=garmetix
POSTGRES_PASSWORD=change-this-database-password
POSTGRES_PORT=5432

JWT_ISSUER=Garmetix
JWT_AUDIENCE=GarmetixWeb
JWT_SIGNING_KEY=change-this-to-a-long-random-production-secret-at-least-32-characters

WEB_PORT=3000
API_PORT=5080
NUXT_PUBLIC_API_BASE=/api
NUXT_API_INTERNAL_BASE=http://api:5080/api

PASSWORD_RESET_FRONTEND_BASE_URL=http://localhost:3000

EMAIL_ENABLED=false
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_ENABLE_SSL=true
EMAIL_USERNAME=your-smtp-username
EMAIL_PASSWORD=your-smtp-password-or-app-password
EMAIL_FROM_EMAIL=no-reply@example.com
EMAIL_FROM_NAME=Garmetix
EMAIL_REPLY_TO_EMAIL=

DATABASE_AUTO_MIGRATE=true

PAYROLL_AUTOMATION_ENABLED=true
PAYROLL_AUTOMATION_TIME_ZONE=Asia/Kolkata
PAYROLL_AUTOMATION_RUN_HOUR=2
PAYROLL_AUTOMATION_RUN_MINUTE=0
PAYROLL_AUTOMATION_RUN_ON_STARTUP=true

BACKUP_ENABLED=true
BACKUP_TIME_ZONE=Asia/Kolkata
BACKUP_RUN_HOUR=2
BACKUP_RUN_MINUTE=30
BACKUP_RUN_ON_STARTUP=false
BACKUP_RETENTION_COUNT=14

# Google Drive online backup. Create ./secrets/google-drive-service-account.json
# and share the target Drive folder with the service account client_email.
GOOGLE_DRIVE_BACKUP_ENABLED=false
GOOGLE_DRIVE_UPLOAD_ON_BACKUP=true
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id
GOOGLE_DRIVE_RETENTION_COUNT=30

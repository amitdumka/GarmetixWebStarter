# Copy this file to deploy/macmini.env and edit only the placeholder values.
# This file is used by deploy/deploy-to-macmini.sh on your local/laptop/desktop machine.

SERVER_HOST=192.168.11.126
SERVER_USER=amit
SSH_PORT=22

# Safer option: keep blank and use SSH key auth.
# For password automation, put your SSH password here locally only; do not commit/share it.
SSH_PASSWORD=CHANGE_ME_SSH_PASSWORD

# If sudo password is same as SSH password, leave blank.
SUDO_PASSWORD=

REMOTE_APP_DIR=/opt/garmetix
DOMAIN=garmetix.aadwikafashion.in
PUBLIC_HTTPS_URL=https://garmetix.aadwikafashion.in

# Optional but recommended: fully automatic Cloudflare Tunnel + DNS creation.
# Required Cloudflare API token permissions:
# - Account: Cloudflare Tunnel Edit / Cloudflare Tunnel Write
# - Zone: DNS Edit / DNS Write
# - Account: Read is useful for verification
CLOUDFLARE_API_TOKEN=CHANGE_ME_CLOUDFLARE_API_TOKEN
CLOUDFLARE_ACCOUNT_ID=

# Note: if CLOUDFLARE_ACCOUNT_ID is blank, the script will try to auto-detect it
# from CLOUDFLARE_API_TOKEN. If your token has no Account Read permission, paste it manually.
CLOUDFLARE_ZONE_ID=0999019e81006bb9cdfa22e702f42374
CLOUDFLARE_TUNNEL_NAME=garmetix-macmini

# Advanced: if you already created a tunnel manually, paste both values and skip API tunnel creation.
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_TOKEN=

# Fresh schema bootstrap mode for clean installs.
DATABASE_SCHEMA_BOOTSTRAP_MODE=FreshBaseline

# Set true only for first fresh install or failed test database reset. Destructive: removes PostgreSQL Docker volume.
RESET_DATABASE_ON_DEPLOY=false

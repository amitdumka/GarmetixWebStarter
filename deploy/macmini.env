# Garmetix Mac mini deployment config for WSL -> Ubuntu Server -> Docker -> Cloudflare Tunnel
# Keep this file private. Do not commit/share it.

SERVER_HOST=192.168.11.126
SERVER_USER=amit
SSH_PORT=22

# Put your Mac mini SSH password here before running deploy from WSL.
# Safer option: keep this as CHANGE_ME_SSH_PASSWORD and use SSH key login.
SSH_PASSWORD=CHANGE_ME_SSH_PASSWORD

# If sudo password is same as SSH password, leave blank.
SUDO_PASSWORD=

REMOTE_APP_DIR=/opt/garmetix
DOMAIN=garmetix.aadwikafashion.in
PUBLIC_HTTPS_URL=https://garmetix.aadwikafashion.in

# Cloudflare automation.
# Your supplied Account ID contained a placeholder text, so this is intentionally blank.
# The deployment script will try to auto-detect the account using the API token.
# If auto-detect fails, paste the correct 32-character Account ID here.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=0999019e81006bb9cdfa22e702f42374
CLOUDFLARE_TUNNEL_NAME=garmetix-macmini

# Cloudflare API token supplied by user. Keep private and rotate after deployment.
CLOUDFLARE_API_TOKEN=cfut_rII4mjRqEK0HciCD3psx06I7nm0JNAIU6eqFalE807507bd9

# Advanced: if you already created a tunnel manually, paste both values and skip API tunnel creation.
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_TOKEN=

# Fresh schema bootstrap mode for clean installs.
DATABASE_SCHEMA_BOOTSTRAP_MODE=FreshBaseline

# Set true only for first fresh install or failed test database reset. Destructive: removes PostgreSQL Docker volume.
RESET_DATABASE_ON_DEPLOY=false

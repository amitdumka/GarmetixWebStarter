# Root workspace ignores for Version5 modular layout.
node_modules/
.nuxt/
.output/
dist/
outputs/
.env
.env.*
!.env.example
!.env.production.example

# Modular app outputs.
modular/**/.nuxt/
modular/**/.output/
modular/**/node_modules/
modular/**/dist/
modular/docs/generated/

# Legacy keeps its own moved ignore rules under legacy/.gitignore.
legacy/**/node_modules/
legacy/**/.nuxt/
legacy/**/.output/
legacy/**/bin/
legacy/**/obj/
